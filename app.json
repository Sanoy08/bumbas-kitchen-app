{
  "expo": {
    "name": "Bumba's Kitchen",
    "slug": "bumbas-kitchen",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/LOGO.png",
    "scheme": "bumbaskitchenapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/LOGO.png"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "REQUEST_INSTALL_PACKAGES",
        "REQUEST_INSTALL_PACKAGES"
      ],
      "gradleProperties": {
        "reactNativeArchitectures": "arm64-v8a"
      },
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/LOGO.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.bumbaskitchen.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F8F9FA",
          "image": "./assets/LOGO.png",
          "imageWidth": 200
        }
      ],
      "expo-status-bar",
      "expo-secure-store",
      "expo-image",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "40acdafb-c0f4-4185-a987-1f04ce8c59d8"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/40acdafb-c0f4-4185-a987-1f04ce8c59d8",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    }
  }
}